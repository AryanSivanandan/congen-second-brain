{
  "manifest_version": 2,
  "name": "My Page Enhancer",
  "version": "1.0.0",
  "description": "Enhances web pages with custom styling",

  "permissions": [
    "activeTab",
    "tabs",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },

  "commands": {
    "capture-full-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Capture full page"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["libs/readability.js", "content.js"]
    }
  ],

  "icons": {
    "48": "icon.png"
  }
}